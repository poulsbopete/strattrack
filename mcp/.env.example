# Copy to mcp/.env and load before starting Claude Desktop, or export in shell.
# Prefer macOS Keychain for secrets: docs/MACOS_KEYCHAIN.md + scripts/run-strattrack-mcp-from-keychain.sh
ELASTICSEARCH_URL=http://localhost:9200
STRATTRACK_INDEX=strattrack_drawers
# ELASTICSEARCH_API_KEY=   # Kibana “Encoded” API key when ES has security enabled
# ELASTICSEARCH_BASIC_AUTH=   # base64(username:password) if using Basic instead
